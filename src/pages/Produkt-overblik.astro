---
import ProductLoadMore from "../components/ProductLoadMore.astro";
import SearchSection from "../components/SearchSection.astro";
import SiteLayout from "../layouts/SiteLayout.astro";

const supabaseUrl = import.meta.env.SUPABASE_URL;
const supabaseKey = import.meta.env.SUPABASE_KEY;
const defaultZoom = 3;

if (!supabaseUrl || !supabaseKey) {
    throw new Error("Missing Supabase environment variables.");
}
---

<SiteLayout
    title="Produkt overblik"
    description="HIGHLIDE product overview page"
>
    <div
        class="mx-auto max-w-5xl"
        id="product-overview"
        data-zoom={String(defaultZoom)}
        data-supabase-url={supabaseUrl}
        data-supabase-key={supabaseKey}
        data-default-zoom={String(defaultZoom)}
    >
        <SearchSection
            action="/Produkt-overblik"
            compact={true}
            placeholder="Søg efter brands, produkter eller butikker"
        />

        <section class="pb-12 pt-2 md:pb-16">
            <div class="mb-5 flex items-end justify-between gap-4">
                <div>
                    <h1
                        class="text-[1.9rem] font-semibold tracking-[-0.03em] text-[#1e1a17] md:text-[2.3rem]"
                    >
                        Produkt overblik
                    </h1>
                    <p
                        class="mt-1 text-sm text-[#6e645d] md:text-base"
                        data-results-copy
                    >
                        Henter produkter...
                    </p>
                </div>
            </div>

            <div class="p-1 md:p-2">
                <div class="mb-6">
                    <div class="mb-3 flex items-center justify-between gap-3">
                        <h2
                            class="text-[1.55rem] font-semibold tracking-[-0.03em] text-[#1e1a17]"
                        >
                            Zoom niveau
                        </h2>
                        <p
                            class="text-sm font-semibold uppercase tracking-[0.25em] text-[#84786d]"
                            data-zoom-label
                        >
                            Zoom {defaultZoom} ud af 4
                        </p>
                    </div>

                    <input
                        class="zoom-slider h-2 w-full cursor-pointer appearance-none rounded-full bg-[#e8e5e1]"
                        type="range"
                        min="1"
                        max="4"
                        step="1"
                        value={String(defaultZoom)}
                        aria-label="Vælg zoom niveau"
                        data-zoom-slider
                    />
                </div>

                <div
                    class="rounded-[1.5rem] border border-dashed border-black/10 bg-[#f7f2ea] px-6 py-14 text-center"
                    data-loading-state
                >
                    <p class="text-lg font-medium text-[#3e3530]">
                        Henter produkter...
                    </p>
                </div>

                <div
                    class="rounded-[1.5rem] border border-dashed border-black/10 bg-[#f7f2ea] px-6 py-14 text-center"
                    data-empty-state
                    hidden
                >
                    <p class="text-lg font-medium text-[#3e3530]">
                        Vi kunne ikke finde nogle produkter.
                    </p>
                    <p class="mt-2 text-sm text-[#6e645d]">
                        Prøv med et andet søgeord eller fjern din filtrering.
                    </p>
                </div>

                <div
                    class="rounded-[1.5rem] border border-dashed border-black/10 bg-[#f7f2ea] px-6 py-14 text-center"
                    data-error-state
                    hidden
                >
                    <p class="text-lg font-medium text-[#3e3530]">
                        Der opstod en fejl ved hentning af produkter.
                    </p>
                    <p class="mt-2 text-sm text-[#6e645d]">
                        Prøv igen om et øjeblik.
                    </p>
                </div>

                <div class="product-grid grid gap-4" data-product-grid hidden>
                </div>

                <ProductLoadMore />
            </div>
        </section>
    </div>

    <script>
        import { createClient } from "@supabase/supabase-js";

        const overview = document.getElementById("product-overview");
        const supabaseUrl = overview?.dataset.supabaseUrl;
        const supabaseKey = overview?.dataset.supabaseKey;
        const defaultZoom = Number(overview?.dataset.defaultZoom ?? "3");
        const zoomStorageKey = "highlide-product-overview-zoom";

        if (!overview || !supabaseUrl || !supabaseKey) {
            console.error("Missing Supabase config on product overview page.");
        }

        const supabase = createClient(supabaseUrl, supabaseKey);
        const searchInput = document.getElementById("frontpage-search");
        const searchForm = searchInput?.closest("form");
        const slider = overview?.querySelector("[data-zoom-slider]");
        const zoomLabel = overview?.querySelector("[data-zoom-label]");
        const resultsCopy = overview?.querySelector("[data-results-copy]");
        const grid = overview?.querySelector("[data-product-grid]");
        const loadingState = overview?.querySelector("[data-loading-state]");
        const emptyState = overview?.querySelector("[data-empty-state]");
        const errorState = overview?.querySelector("[data-error-state]");
        const loadMoreWrap = overview?.querySelector("[data-load-more-wrap]");
        const loadMoreCopy = overview?.querySelector("[data-load-more-copy]");
        const loadMoreProgress = overview?.querySelector(
            "[data-load-more-progress]",
        );
        const loadMoreButton = overview?.querySelector("[data-load-more]");

        const fallbackImage = "/images/clothes/Brown_coat.png";
        const url = new URL(window.location.href);
        const searchQuery = (url.searchParams.get("q") ?? "").trim();
        const storedZoom =
            window.localStorage.getItem(zoomStorageKey) ?? String(defaultZoom);
        let currentZoom = Math.min(
            4,
            Math.max(
                1,
                Number.parseInt(
                    url.searchParams.get("zoom") ?? storedZoom,
                    10,
                ) || defaultZoom,
            ),
        );

        if (searchInput) {
            searchInput.value = searchQuery;
        }

        let zoomInput = searchForm?.querySelector('input[name="zoom"]');
        if (searchForm && !zoomInput) {
            zoomInput = document.createElement("input");
            zoomInput.type = "hidden";
            zoomInput.name = "zoom";
            searchForm.append(zoomInput);
        }

        let cards = [];
        let loadedCount = 0;
        let totalCount = 0;
        let isFetching = false;
        const zoomConfig = {
            1: { label: "Zoom 1 ud af 4", pageSize: 50 },
            2: { label: "Zoom 2 ud af 4", pageSize: 24 },
            3: { label: "Zoom 3 ud af 4", pageSize: 12 },
            4: { label: "Zoom 4 ud af 4", pageSize: 6 },
        };

        const formatPrice = (value) => {
            if (typeof value !== "number") return value || "Pris ikke angivet";

            return `${new Intl.NumberFormat("da-DK").format(value)} DKK`;
        };

        const mapProduct = (product) => {
            const image = Array.isArray(product.images)
                ? product.images.find(
                      (item) => typeof item === "string" && item,
                  )
                : null;

            return {
                id: product.id,
                brand: product.brand || "Ukendt brand",
                name: product.navn || "Produkt",
                price: formatPrice(product.pris),
                store: product.store || "Ukendt butik",
                detail: product.color || product.category || "Produkt",
                image: image || fallbackImage,
            };
        };

        const createProductCard = (product) => {
            const link = document.createElement("a");
            link.href = `/Produkt-detaljer?id=${product.id}`;
            link.className =
                "product-card block text-[#1e1a17] transition hover:opacity-90";
            link.dataset.productCard = "";
            link.setAttribute(
                "aria-label",
                `Se detaljer for ${product.brand} ${product.name}`,
            );

            const imageWrap = document.createElement("div");
            imageWrap.className =
                "product-image-wrap relative aspect-[0.78] overflow-hidden rounded-[1.15rem] bg-gradient-to-b from-[#e8e1d4] to-[#d8d0c2]";

            const image = document.createElement("img");
            image.src = product.image;
            image.alt = `${product.brand} ${product.name}`;
            image.loading = "lazy";
            image.className = "product-image h-full w-full object-contain";

            imageWrap.append(image);

            const meta = document.createElement("div");
            meta.className = "product-meta grid content-start px-1 pt-3";

            const brand = document.createElement("p");
            brand.className =
                "brand text-[0.95rem] font-extrabold uppercase tracking-[0.1em]";
            brand.textContent = product.brand;

            const name = document.createElement("p");
            name.className = "name mt-[0.15rem] text-base text-[#6e645d]";
            name.textContent = product.name;

            const price = document.createElement("p");
            price.className = "price mt-[0.55rem] text-[1.1rem] font-medium";
            price.textContent = product.price;

            const details = document.createElement("p");
            details.className =
                "details mt-1 text-[0.9rem] uppercase text-[#8a8178]";
            details.textContent = `${product.detail} • ${product.store}`;

            meta.append(brand, name, price, details);
            link.append(imageWrap, meta);

            return link;
        };

        const updateGrid = (updateHistory = true) => {
            if (!overview || !slider || !zoomLabel) return;

            const zoom = Number(slider.value);
            const config = zoomConfig[zoom] ?? zoomConfig[2];
            currentZoom = zoom;
            overview.dataset.zoom = String(zoom);
            zoomLabel.textContent = config.label;
            if (zoomInput) {
                zoomInput.value = String(zoom);
            }

            window.localStorage.setItem(zoomStorageKey, String(zoom));

            if (updateHistory) {
                const nextUrl = new URL(window.location.href);
                nextUrl.searchParams.set("zoom", String(zoom));
                nextUrl.searchParams.delete("page");
                window.history.replaceState({}, "", nextUrl);
            }

            cards.forEach((card) => {
                card.hidden = false;
            });
        };

        const updateResultsCopy = (count, query) => {
            if (!resultsCopy) return;

            if (count > 0) {
                resultsCopy.textContent = `${count} resultater${query ? ` for “${query}”` : ""}`;
                return;
            }

            resultsCopy.textContent = `Ingen resultater${query ? ` for “${query}”` : ""}`;
        };

        const updateLoadMoreState = () => {
            if (!loadMoreWrap || !loadMoreCopy || !loadMoreProgress) return;

            if (totalCount <= 0) {
                loadMoreWrap.hidden = true;
                return;
            }

            const visibleCount = Math.min(loadedCount, totalCount);
            const progress = Math.min(100, (visibleCount / totalCount) * 100);
            loadMoreCopy.textContent = `Viser ${visibleCount} af ${totalCount} produkter`;
            loadMoreProgress.style.width = `${progress}%`;
            loadMoreWrap.hidden = false;

            if (loadMoreButton) {
                loadMoreButton.hidden = visibleCount >= totalCount;
                loadMoreButton.disabled = isFetching;
                loadMoreButton.textContent = isFetching
                    ? "Henter..."
                    : "Indlæs flere";
            }
        };

        const setState = ({
            loading = false,
            empty = false,
            error = false,
            gridVisible = false,
        }) => {
            loadingState?.toggleAttribute("hidden", !loading);
            emptyState?.toggleAttribute("hidden", !empty);
            errorState?.toggleAttribute("hidden", !error);
            grid?.toggleAttribute("hidden", !gridVisible);
            if (error) {
                loadMoreWrap?.toggleAttribute("hidden", true);
            }
        };

        const fetchProducts = async ({ reset = false } = {}) => {
            if (isFetching) return;
            isFetching = true;

            if (reset) {
                loadedCount = 0;
                totalCount = 0;
                cards = [];
                if (grid) grid.innerHTML = "";
                setState({ loading: true });
            } else {
                updateLoadMoreState();
            }

            const config = zoomConfig[currentZoom] ?? zoomConfig[defaultZoom];
            const pageSize = config.pageSize;
            const from = loadedCount;
            const to = from + pageSize - 1;

            let query = supabase
                .from("products")
                .select(
                    "id, brand, navn, pris, store, color, category, images",
                    {
                        count: "exact",
                    },
                )
                .order("id", { ascending: true })
                .range(from, to);

            if (searchQuery) {
                query = query.or(
                    `navn.ilike.%${searchQuery}%,brand.ilike.%${searchQuery}%,store.ilike.%${searchQuery}%,category.ilike.%${searchQuery}%`,
                );
            }

            const { data, error, count } = await query;

            if (error) {
                console.error(error);
                updateResultsCopy(0, searchQuery);
                setState({ error: true });
                isFetching = false;
                updateLoadMoreState();
                return;
            }

            const products = (data ?? []).map(mapProduct);
            totalCount = count ?? loadedCount + products.length;
            loadedCount += products.length;

            updateResultsCopy(totalCount, searchQuery);

            if (!grid) {
                isFetching = false;
                updateLoadMoreState();
                return;
            }

            products.forEach((product) =>
                grid.append(createProductCard(product)),
            );

            cards = [...grid.querySelectorAll("[data-product-card]")];

            if (products.length === 0) {
                setState({ empty: true });
                isFetching = false;
                updateLoadMoreState();
                return;
            }

            setState({ gridVisible: true });
            updateGrid(false);
            isFetching = false;
            updateLoadMoreState();
        };

        if (slider) {
            slider.value = String(currentZoom);
        }
        updateGrid(false);

        slider?.addEventListener("input", () => {
            updateGrid(true);
            fetchProducts({ reset: true });
        });

        loadMoreButton?.addEventListener("click", () => {
            fetchProducts();
        });

        fetchProducts({ reset: true });
    </script>

    <style is:global>
        .zoom-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            height: 1.6rem;
            width: 1.6rem;
            border-radius: 999px;
            background: #4e1515;
            box-shadow: 0 4px 16px rgba(78, 21, 21, 0.24);
            border: 0;
        }

        .zoom-slider::-moz-range-thumb {
            height: 1.6rem;
            width: 1.6rem;
            border: 0;
            border-radius: 999px;
            background: #4e1515;
            box-shadow: 0 4px 16px rgba(78, 21, 21, 0.24);
        }

        #product-overview[data-zoom="1"] .product-grid {
            grid-template-columns: repeat(6, minmax(0, 1fr));
            gap: 0.45rem;
        }

        #product-overview[data-zoom="1"] .product-image-wrap {
            border-radius: 0.15rem;
            aspect-ratio: 0.74;
        }

        #product-overview[data-zoom="1"] .product-meta {
            padding: 0.3rem 0 0;
        }

        #product-overview[data-zoom="1"] .brand,
        #product-overview[data-zoom="1"] .price,
        #product-overview[data-zoom="1"] .details {
            display: none;
        }

        #product-overview[data-zoom="1"] .name {
            display: block;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            margin-top: 0;
            font-size: 0.66rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: #2a221d;
        }

        #product-overview[data-zoom="2"] .product-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 1.6rem 1rem;
        }

        #product-overview[data-zoom="2"] .brand,
        #product-overview[data-zoom="2"] .name,
        #product-overview[data-zoom="3"] .brand,
        #product-overview[data-zoom="3"] .name,
        #product-overview[data-zoom="4"] .brand,
        #product-overview[data-zoom="4"] .name {
            display: -webkit-box;
            overflow: hidden;
            overflow-wrap: anywhere;
            word-break: break-word;
            -webkit-box-orient: vertical;
            line-height: 1.25;
            min-height: 2.5em;
        }

        #product-overview[data-zoom="2"] .brand {
            -webkit-line-clamp: 2;
        }

        #product-overview[data-zoom="2"] .name {
            -webkit-line-clamp: 2;
        }

        #product-overview[data-zoom="2"] .price {
            margin-top: 0.4rem;
        }

        #product-overview[data-zoom="3"] .product-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 1.5rem 1rem;
        }

        #product-overview[data-zoom="4"] .product-grid {
            grid-template-columns: 1fr;
            gap: 1.25rem;
        }

        #product-overview[data-zoom="4"] .product-card {
            display: block;
        }

        #product-overview[data-zoom="4"] .product-meta {
            padding-top: 0.8rem;
        }

        @media (max-width: 768px) {
            #product-overview[data-zoom="1"] .product-grid {
                grid-template-columns: repeat(5, minmax(0, 1fr));
            }

            #product-overview[data-zoom="2"] .product-grid,
            #product-overview[data-zoom="3"] .product-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 520px) {
            #product-overview[data-zoom="1"] .product-grid {
                grid-template-columns: repeat(5, minmax(0, 1fr));
                gap: 0.45rem;
            }

            #product-overview[data-zoom="1"] .name {
                font-size: 0.58rem;
            }

            #product-overview[data-zoom="2"] .product-grid {
                grid-template-columns: repeat(3, minmax(0, 1fr));
                gap: 1rem 0.7rem;
            }

            #product-overview[data-zoom="2"] .product-image-wrap {
                border-radius: 0;
                aspect-ratio: 0.73;
            }

            #product-overview[data-zoom="2"] .product-meta {
                padding: 0.55rem 0.15rem 0;
            }

            #product-overview[data-zoom="2"] .brand {
                font-size: 0.82rem;
            }

            #product-overview[data-zoom="2"] .name {
                font-size: 0.9rem;
            }

            #product-overview[data-zoom="2"] .price {
                margin-top: 0.3rem;
                font-size: 0.95rem;
            }

            #product-overview[data-zoom="2"] .details {
                display: none;
            }

            #product-overview[data-zoom="3"] .product-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            #product-overview[data-zoom="4"] .product-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</SiteLayout>
