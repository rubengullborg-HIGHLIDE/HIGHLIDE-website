---
const footerLinks = [
    { href: "/Om-Highlide", label: "Om HIGHLIDE" },
    { href: "/Hjaelp-kontakt", label: "Kontakt" },
];

const socialLinks = [
    {
        href: "https://www.instagram.com/",
        label: "Instagram",
        bgClass: "bg-[#ff2d55]",
        icon: "instagram",
    },
    {
        href: "https://www.facebook.com/",
        label: "Facebook",
        bgClass: "bg-[#1877f2]",
        icon: "facebook",
    },
    {
        href: "https://www.linkedin.com/",
        label: "LinkedIn",
        bgClass: "bg-[#0a66c2]",
        icon: "linkedin",
    },
];
---

<footer class="mt-10 bg-[#dbeafc]">
    <div class="mx-auto max-w-[1120px] px-6 py-10 md:px-8 md:py-14">
        <div class="max-w-[28rem]">
            <a
                class="inline-block text-[3rem] font-black uppercase leading-none tracking-tight text-[#121212] sm:text-[4.25rem]"
                href="/"
                aria-label="HIGHLIDE"
            >
                HIGHLIDE
            </a>
            <p class="mt-3 max-w-[23rem] text-base leading-8 text-[#474c54]">
                Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
                eiusmod tempor incididunt ut labore et dolore magna aliqua.
            </p>
        </div>

        <div class="mt-10 space-y-3 text-[#121212]">
            {
                footerLinks.map((link) => (
                    <a
                        class="block text-[1.25rem] font-normal leading-tight transition hover:opacity-70 sm:text-[1.4rem]"
                        href={link.href}
                    >
                        {link.label}
                    </a>
                ))
            }

            <p class="pt-1 text-base leading-6 text-[#2e343d]">
                L.P. Bechs Vej 27, 8240 Risskov
            </p>
            <p class="pt-1 text-base leading-6 text-[#2e343d]">CVR: 45744787</p>
            <div class="flex items-center gap-2 pt-1">
                {
                    socialLinks.map((link) => (
                        <a
                            class={`inline-flex h-8 w-8 items-center justify-center rounded-full text-white transition hover:scale-[1.03] ${link.bgClass}`}
                            href={link.href}
                            aria-label={link.label}
                        >
                            {link.icon === "instagram" && (
                                <svg
                                    viewBox="0 0 24 24"
                                    class="h-[1.05rem] w-[1.05rem]"
                                    fill="none"
                                    aria-hidden="true"
                                >
                                    <rect
                                        x="4.5"
                                        y="4.5"
                                        width="15"
                                        height="15"
                                        rx="4"
                                        stroke="currentColor"
                                        stroke-width="2"
                                    />
                                    <circle
                                        cx="12"
                                        cy="12"
                                        r="3.5"
                                        stroke="currentColor"
                                        stroke-width="2"
                                    />
                                    <circle
                                        cx="17.2"
                                        cy="6.8"
                                        r="1.1"
                                        fill="currentColor"
                                    />
                                </svg>
                            )}
                            {link.icon === "facebook" && (
                                <svg
                                    viewBox="0 0 24 24"
                                    class="h-[1rem] w-[1rem]"
                                    fill="currentColor"
                                    aria-hidden="true"
                                >
                                    <path d="M13.3 20v-7h2.4l.4-2.8h-2.8V8.4c0-.8.2-1.3 1.4-1.3h1.5V4.6c-.3 0-1.1-.1-2-.1-2 0-3.4 1.2-3.4 3.5v2.2H8.5V13h2.3v7h2.5Z" />
                                </svg>
                            )}
                            {link.icon === "linkedin" && (
                                <svg
                                    viewBox="0 0 24 24"
                                    class="h-[1rem] w-[1rem]"
                                    fill="currentColor"
                                    aria-hidden="true"
                                >
                                    <path d="M6.4 8.2a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Zm-1.3 10.6h2.6v-8.2H5.1v8.2Zm4.1 0h2.6v-4.6c0-1.2.2-2.4 1.7-2.4s1.5 1.4 1.5 2.5v4.5h2.6v-5c0-2.4-.5-4.3-3.3-4.3-1.3 0-2.1.7-2.5 1.4h-.1v-1.2H9.2c0 .8 0 1.6 0 2.5v6.6Z" />
                                </svg>
                            )}
                        </a>
                    ))
                }
            </div>
        </div>
    </div>
</footer>
