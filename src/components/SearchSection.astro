---
interface Props {
    heading?: string;
    description?: string;
    placeholder?: string;
    buttonLabel?: string;
    action?: string;
    value?: string;
    compact?: boolean;
}

const {
    heading = "Find din stil",
    description =
        "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.",
    placeholder = "Søg efter tøj...",
    buttonLabel = "Søg",
    action = "",
    value = "",
    compact = false,
} = Astro.props;
---

<section
    class:list={[
        "mx-auto flex w-full flex-col",
        compact
            ? "max-w-5xl gap-6 py-4 md:py-6"
            : "max-w-3xl items-center gap-8 py-16 text-center md:py-24",
    ]}
>
    {
        !compact && (
            <div class="space-y-3">
                <h1 class="text-5xl font-semibold uppercase tracking-[0.04em] text-[#1e1a17] md:text-6xl">
                    {heading}
                </h1>
                <p class="mx-auto max-w-2xl text-base leading-7 text-[#5c534b] md:text-lg">
                    {description}
                </p>
            </div>
        )
    }

    <form class:list={["w-full", compact ? "max-w-none" : "max-w-2xl"]} role="search" method="get" action={action}>
        <label class="sr-only" for="frontpage-search">{placeholder}</label>
        <div
            class:list={[
                "flex items-center rounded-full border border-black/15 bg-white p-2 transition focus-within:border-[#420E0E] focus-within:ring-1 focus-within:ring-[#420E0E]",
                compact && "shadow-[0_12px_30px_rgba(53,33,18,0.08)]",
            ]}
        >
            <input
                id="frontpage-search"
                name="q"
                type="search"
                placeholder={placeholder}
                data-placeholder={placeholder}
                value={value}
                onfocus="this.placeholder = '';"
                onblur="if (!this.value) this.placeholder = this.dataset.placeholder || '';"
                class:list={[
                    "min-w-0 flex-1 border-0 bg-transparent text-[#1e1a17] placeholder:text-[#8a8178] focus:outline-none",
                    compact ? "px-4 py-4 text-[1.05rem]" : "px-4 py-3 text-base",
                ]}
            />
            <button
                type="submit"
                class="shrink-0 cursor-pointer rounded-full bg-[#420E0E] px-6 py-3 text-base font-medium text-white transition hover:opacity-90"
            >
                {buttonLabel}
            </button>
        </div>
    </form>
</section>
