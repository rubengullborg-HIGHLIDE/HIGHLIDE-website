---
interface Props {
    heading?: string;
    text?: string;
}

const {
    text = "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.",
} = Astro.props;

const clothes = [
    {
        src: "/images/clothes/Blue_shirt.png",
        alt: "Blå skjorte",
        className:
            "left-[-0.75rem] top-[-8%] w-14 -rotate-12 sm:w-16 md:left-[-5rem] md:top-[-12%] md:w-28 lg:w-32",
    },
    {
        src: "/images/clothes/Brown_coat.png",
        alt: "Brun frakke",
        className:
            "right-[-0.5rem] top-[-10%] w-16 rotate-12 sm:w-20 md:right-[-5rem] md:top-[-16%] md:w-32 lg:w-36",
    },
    {
        src: "/images/clothes/Striped_pants.png",
        alt: "Stribede bukser",
        className:
            "left-[1%] bottom-[-8%] w-16 rotate-[-8deg] sm:w-20 md:left-[-5rem] md:bottom-[-12%] md:w-32 lg:w-36",
    },
    {
        src: "/images/clothes/Brown_shoes.png",
        alt: "Brune sko",
        className:
            "right-[3%] bottom-[-8%] w-14 rotate-[10deg] sm:w-16 md:right-[-5rem] md:bottom-[-12%] md:w-28 lg:w-32",
    },
];
---

<section class="mx-auto w-full max-w-5xl md:-mt-12">
    <div class="mx-auto max-w-3xl text-center">
        <p class="mt-4 text-base leading-8 text-[#5c534b] md:text-lg">
            {text}
        </p>
        <a
            href="/Om-Highlide"
            class="mt-4 inline-flex items-center text-sm font-medium text-[#420E0E] underline underline-offset-4 transition hover:opacity-80"
        >
            Læs mere
        </a>
    </div>

    <div class="relative mt-8 md:mt-10">
        <div class="relative mx-auto max-w-3xl overflow-visible">
            {
                clothes.map((item) => (
                    <img
                        src={item.src}
                        alt={item.alt}
                        class={`pointer-events-none absolute z-0 hidden select-none md:block ${item.className}`}
                    />
                ))
            }

            <img
                src="/images/background/Walking_people.jpg"
                alt="People walking"
                class="relative z-10 mx-auto w-full max-w-3xl rounded-[1.5rem] sm:rounded-[2rem]"
            />
        </div>
    </div>
</section>
