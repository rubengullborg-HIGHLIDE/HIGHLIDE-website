---
import "../styles/global.css";

interface Props {
    title?: string;
    description?: string;
}

const { title = "HIGHLIDE", description = "HIGHLIDE site layout" } =
    Astro.props;
type NavItem = {
    href: string;
    label: string;
    icon?: string;
};

type NavSection = {
    heading?: string;
    items: NavItem[];
};

const navSections: NavSection[] = [
    {
        heading: "Sider",
        items: [
            { href: "/", label: "Forside", icon: "/icons/Rektangler_icon.svg" },
            {
                href: "/Butiks-info",
                label: "Butikker",
                icon: "/icons/Butik_icon.svg",
            },
            {
                href: "/Produkt-overblik",
                label: "Produkter",
                icon: "/icons/Produkt_icon.svg",
            },
        ],
    },
    {
        heading: "Personligt",
        items: [
            {
                href: "/Profil",
                label: "Profil",
                icon: "/icons/Profil_icon.svg",
            },
            {
                href: "/Gemte-produkter",
                label: "Favoritter",
                icon: "/icons/Taske_icon.svg",
            },
        ],
    },
    {
        items: [
            { href: "/Om-Highlide", label: "Om HIGHLIDE" },
            { href: "/Hjaelp-kontakt", label: "Hjælp & Kontakt" },
            { href: "/Auth", label: "Log ind" },
        ],
    },
];
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description} />
        <meta name="generator" content={Astro.generator} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <title>{title}</title>
    </head>
    <body
        class="min-h-screen bg-[radial-gradient(circle_at_top_left,_rgba(186,160,120,0.22),_transparent_34%),linear-gradient(180deg,_#f8f3ea_0%,_#f2ece2_100%)] text-[#1e1a17]"
    >
        <div class="min-h-screen" id="site-shell" data-drawer-open="false">
            <header
                class="sticky top-0 z-20 border-b border-black/10 bg-[#f8f4ec]/85 backdrop-blur-md"
            >
                <div
                    class="mx-auto grid max-w-[1120px] grid-cols-[auto_1fr_auto] items-center px-4 py-4 md:px-8"
                >
                    <button
                        class="inline-flex h-11 w-11 shrink-0 items-center justify-center bg-transparent text-[#1e1a17] transition hover:opacity-70"
                        type="button"
                        aria-label="Open menu"
                        aria-controls="site-drawer"
                        aria-expanded="false"
                        data-menu-button
                    >
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            aria-hidden="true"
                            class="h-5 w-5"
                        >
                            <path
                                d="M4 7H20M4 12H20M4 17H20"
                                stroke="currentColor"
                                stroke-width="1.8"
                                stroke-linecap="round"></path>
                        </svg>
                    </button>

                    <a
                        class="justify-self-center inline-flex items-center"
                        href="/"
                        aria-label="HIGHLIDE home"
                    >
                        <img
                            src="/HIGHLIDE_logo_dark.png"
                            alt="HIGHLIDE"
                            class="h-7 w-auto md:h-8"
                        />
                    </a>
                </div>
            </header>

            <div
                class="fixed inset-0 z-30 bg-black/30 opacity-0 pointer-events-none transition-opacity duration-200"
                data-drawer-overlay
                hidden
            >
            </div>

            <aside
                class="fixed left-0 top-0 z-40 flex h-dvh w-[min(22rem,88vw)] -translate-x-full flex-col border-r border-black/10 bg-[#f8f4ec] shadow-[0_20px_50px_rgba(58,44,31,0.12)] transition-transform duration-200"
                id="site-drawer"
                aria-hidden="true"
            >
                <div
                    class="flex items-center justify-between gap-4 border-b border-black/10 px-4 py-4"
                >
                    <div class="text-sm font-bold uppercase tracking-[0.06em]">
                        Menu
                    </div>
                    <button
                        class="inline-flex h-9 w-9 items-center justify-center bg-transparent text-[#1e1a17] transition hover:opacity-70"
                        type="button"
                        aria-label="Close menu"
                        data-drawer-close
                    >
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            aria-hidden="true"
                            class="h-5 w-5"
                        >
                            <path
                                d="M6 6L18 18M18 6L6 18"
                                stroke="currentColor"
                                stroke-width="1.8"
                                stroke-linecap="round"></path>
                        </svg>
                    </button>
                </div>
                <nav class="space-y-6 px-4 py-5">
                    {
                        navSections.map((section) => (
                            <section>
                                {section.heading && (
                                    <h2 class="mb-2 text-xs font-bold uppercase tracking-[0.08em] text-[#6f655b]">
                                        {section.heading}
                                    </h2>
                                )}
                                <ul class="space-y-1">
                                    {section.items.map((item) => (
                                        <li>
                                            <a
                                                class="flex min-h-12 items-center gap-3 rounded-none px-0 py-3 text-base font-medium text-[#1e1a17] transition hover:opacity-70"
                                                href={item.href}
                                            >
                                                {item.icon && (
                                                    <img
                                                        src={item.icon}
                                                        alt=""
                                                        aria-hidden="true"
                                                        class="h-5 w-5 shrink-0 object-contain"
                                                    />
                                                )}
                                                <span>{item.label}</span>
                                            </a>
                                        </li>
                                    ))}
                                </ul>
                            </section>
                        ))
                    }
                </nav>
            </aside>

            <main class="px-4 py-8 md:px-8">
                <div class="mx-auto w-full max-w-[1120px]">
                    <slot />
                </div>
            </main>
        </div>

        <script is:inline>
            const shell = document.getElementById("site-shell");
            const menuButton = document.querySelector("[data-menu-button]");
            const drawer = document.getElementById("site-drawer");
            const overlay = document.querySelector("[data-drawer-overlay]");
            const closeButton = document.querySelector("[data-drawer-close]");

            const setDrawerOpen = (open) => {
                shell.dataset.drawerOpen = String(open);
                menuButton.setAttribute("aria-expanded", String(open));
                drawer.setAttribute("aria-hidden", String(!open));
                overlay.hidden = !open;

                if (open) {
                    drawer.classList.remove("-translate-x-full");
                    drawer.classList.add("translate-x-0");
                    overlay.classList.remove(
                        "opacity-0",
                        "pointer-events-none",
                    );
                    overlay.classList.add("opacity-100", "pointer-events-auto");
                    document.body.classList.add("overflow-hidden");
                } else {
                    drawer.classList.add("-translate-x-full");
                    drawer.classList.remove("translate-x-0");
                    overlay.classList.add("opacity-0", "pointer-events-none");
                    overlay.classList.remove(
                        "opacity-100",
                        "pointer-events-auto",
                    );
                    document.body.classList.remove("overflow-hidden");
                }
            };

            menuButton?.addEventListener("click", () =>
                setDrawerOpen(shell.dataset.drawerOpen !== "true"),
            );
            closeButton?.addEventListener("click", () => setDrawerOpen(false));
            overlay?.addEventListener("click", () => setDrawerOpen(false));
            window.addEventListener("keydown", (event) => {
                if (event.key === "Escape") setDrawerOpen(false);
            });
        </script>
    </body>
</html>
